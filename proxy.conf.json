{
  "/api/*": {
    "target": "http://localhost:7136",
    "secure": false,
    "changeOrigin": true,
    "logLevel": "debug"
  },
  "/auth-api/*": {
    "target": "http://localhost:5200",
    "secure": false,
    "changeOrigin": true,
    "pathRewrite": { "^/auth-api": "" },
    "logLevel": "debug"
  },
  "/docs-api": {
    "target": "http://localhost:5200",
    "secure": false,
    "changeOrigin": true,
    "pathRewrite": { "^/docs-api": "" },
    "logLevel": "debug"
  }
}